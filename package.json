{
  "name": "team-context-mcp",
  "version": "0.3.0",
  "description": "MCP server enforcing AI MIQ SOP v0.4 workflow over multica + git",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "pnpm -r --filter './packages/*' test",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "dev:remote": "pnpm --filter @tcmcp/remote dev",
    "docker:build": "docker build -t tcmcp:dev ."
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
